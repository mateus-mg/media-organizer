# ============================================================
# Media Organization System - Configuration (.env)
# ============================================================
# 
# SUPPORTED MEDIA TYPES: Music, Books, Comics
# 
# Setup Instructions:
# 1. Copy this file to .env
# 2. Update paths to match your system
# 3. Configure external service credentials (optional)
# 4. Run: python3 -m src.main test
#
# ============================================================

# ============================================================
# LIBRARY PATHS (where media is organized)
# ============================================================

# Music library: Artist/Album/Track structure
LIBRARY_PATH_MUSIC="/media/mateus/Servidor/containers/media/library/musics"

# Books library: Author/Title/Book structure
LIBRARY_PATH_BOOKS="/media/mateus/Servidor/containers/media/library/books"

# Comics library: Series/Issue structure
LIBRARY_PATH_COMICS="/media/mateus/Servidor/containers/media/library/comics"


# ============================================================
# DOWNLOAD PATHS (where to monitor for new media)
# ============================================================

# Music download folder
DOWNLOAD_PATH_MUSIC="/media/mateus/Servidor/containers/media/downloads/musics"

# Books download folder
DOWNLOAD_PATH_BOOKS="/media/mateus/Servidor/containers/media/downloads/books"

# Comics download folder
DOWNLOAD_PATH_COMICS="/media/mateus/Servidor/containers/media/downloads/comics"

# Online metadata enrichment for music
ENRICH_MUSIC_METADATA_ONLINE="false"


# ============================================================
# CALIBRE INTEGRATION (OPTIONAL)
# ============================================================
# For PDF to EPUB conversion and advanced book management

CALIBRE_ENABLED="false"
CALIBRE_LIBRARY_PATH="/path/to/calibre/library"

ENRICH_BOOK_METADATA="true"
ENRICH_BOOK_METADATA_ONLINE="false"
ENRICH_BOOK_METADATA_GOOGLE_BOOKS="true"
BOOK_COVER_MIN_MATCH_SCORE="80"
BOOK_METADATA_TRUST_MODE="missing_only"

# Optional but recommended for Google Books online enrichment.
# Without your own key, Google can return quota/rate-limit errors (429/403).
GOOGLE_BOOKS_API_KEY=""

CONVERT_PDF_TO_EPUB="false"

# Book format priority (highest to lowest)
# System skips organizing if a better format already exists
BOOK_FORMAT_PRIORITY="epub,mobi,azw3,azw,pdf"



# ============================================================
# SYSTEM CONFIGURATION
# ============================================================

# Dry-run mode: Preview operations without making changes
DRY_RUN_MODE="false"
DRY_RUN_LOG_LEVEL="INFO"

# Check for new media every N seconds
ORGANIZATION_CHECK_INTERVAL="300"

# Conflict resolution when file already exists
# Options: skip, rename, overwrite
CONFLICT_STRATEGY="skip"
CONFLICT_RENAME_PATTERN="{name}_{counter}{ext}"
CONFLICT_MAX_ATTEMPTS="100"

# Concurrent file operations
MAX_CONCURRENT_FILE_OPS="3"
FILE_OP_DELAY_MS="100"


# ============================================================
# DATABASE & STORAGE
# ============================================================

# JSON database file (tracks all organized media)
DATABASE_PATH="./data/organization.json"

# Automatic backups
DATABASE_BACKUP_ENABLED="true"
DATABASE_BACKUP_KEEP_DAYS="7"

# Trash system for safe deletion
TRASH_ENABLED="true"
TRASH_PATH="./data/trash"
TRASH_RETENTION_DAYS="30"

# Hardlink registry database
LINK_REGISTRY_PATH="./data/link_registry.json"

# Deletion confirmation
DELETE_CONFIRMATION_REQUIRED="true"
DELETE_DRY_RUN_DEFAULT="true"


# ============================================================
# LOGGING
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# Log file location
LOG_FILE="./logs/organizer.log"

# Log rotation
LOG_MAX_SIZE_MB="50"
LOG_BACKUP_COUNT="5"

# Health check (optional)
HEALTH_CHECK_ENABLED="true"
HEALTH_CHECK_HOST="127.0.0.1"
HEALTH_CHECK_PORT="8765"
