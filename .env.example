# ========================================
# Media Organization System Configuration
# ========================================

# -------------------- Library Paths --------------------
LIBRARY_PATH_MOVIES="/media/mateus/Servidor/containers/media/library/movies"
LIBRARY_PATH_TV="/media/mateus/Servidor/containers/media/library/tv"
LIBRARY_PATH_ANIMES="/media/mateus/Servidor/containers/media/library/animes"
LIBRARY_PATH_DORAMAS="/media/mateus/Servidor/containers/media/library/doramas"
LIBRARY_PATH_MUSIC="/media/mateus/Servidor/containers/media/library/musics"
LIBRARY_PATH_BOOKS="/media/mateus/Servidor/containers/media/library/books"
LIBRARY_PATH_COMICS="/media/mateus/Servidor/containers/media/library/comics"

# -------------------- Download Paths --------------------
DOWNLOAD_PATH_MOVIES="/media/mateus/Servidor/containers/media/downloads/movies"
DOWNLOAD_PATH_TV="/media/mateus/Servidor/containers/media/downloads/tv"
DOWNLOAD_PATH_ANIMES="/media/mateus/Servidor/containers/media/downloads/animes"
DOWNLOAD_PATH_DORAMAS="/media/mateus/Servidor/containers/media/downloads/doramas"
DOWNLOAD_PATH_MUSIC="/media/mateus/Servidor/containers/media/downloads/musics"
DOWNLOAD_PATH_BOOKS="/media/mateus/Servidor/containers/media/downloads/books"
DOWNLOAD_PATH_COMICS="/media/mateus/Servidor/containers/media/downloads/comics"
DOWNLOAD_PATH_TORRENTS="/media/mateus/Servidor/containers/media/downloads/torrents"

# -------------------- TMDB API (IDs Only) --------------------
# Get your free API key at: https://www.themoviedb.org/settings/api
# Used ONLY for extracting IDs to add to folder names
TMDB_API_KEY="your_api_key_here"
TMDB_USE_FALLBACK_PARSING="true"

# -------------------- Jellyfin API --------------------
JELLYFIN_URL="http://192.168.1.239:8096"
JELLYFIN_USERNAME="Organizer"
JELLYFIN_PASSWORD="your_password_here"
JELLYFIN_SYNC_PLAYLISTS="true"
JELLYFIN_PLAYLIST_SYNC_INTERVAL="1800"
JELLYFIN_MIN_WAIT_AFTER_ORGANIZATION="600"

# -------------------- Music Automation Integration --------------------
MUSIC_AUTOMATION_DB_PATH="/media/mateus/Servidor/scripts/music-automation/data/downloaded.json"

# -------------------- qBittorrent (Docker) --------------------
QBITTORRENT_ENABLED="true"
QBITTORRENT_HOST="http://localhost:8080"
QBITTORRENT_USERNAME="admin"
QBITTORRENT_PASSWORD="your_password_here"
QBITTORRENT_WATCH_FOLDER="/media/mateus/Servidor/containers/media/downloads/torrents"
QBITTORRENT_CHECK_COMPLETION="true"
QBITTORRENT_STATES_TO_PROCESS="seeding,pausedUP"
QBITTORRENT_MIN_PROGRESS="1.0"

# -------------------- Rate Limiting --------------------
MAX_CONCURRENT_FILE_OPS="3"
MAX_CONCURRENT_API_CALLS="2"
TMDB_RATE_LIMIT_PER_SECOND="4"
JELLYFIN_RATE_LIMIT_PER_SECOND="10"
FILE_OP_DELAY_MS="100"

# -------------------- Dry-Run Mode --------------------
DRY_RUN_MODE="false"
DRY_RUN_LOG_LEVEL="INFO"

# -------------------- Health Check --------------------
HEALTH_CHECK_ENABLED="true"
HEALTH_CHECK_HOST="127.0.0.1"
HEALTH_CHECK_PORT="8765"

# -------------------- Conflict Resolution --------------------
# Options: skip, rename, overwrite
CONFLICT_STRATEGY="skip"
CONFLICT_RENAME_PATTERN="{name}_{counter}{ext}"
CONFLICT_MAX_ATTEMPTS="100"

# -------------------- Scheduling --------------------
ORGANIZATION_CHECK_INTERVAL="300"
PLAYLIST_SYNC_INTERVAL="1800"

# -------------------- Database --------------------
DATABASE_PATH="./data/organization.json"
DATABASE_BACKUP_ENABLED="true"
DATABASE_BACKUP_KEEP_DAYS="7"

# -------------------- Logging --------------------
LOG_LEVEL="INFO"
LOG_FILE="./logs/organizer.log"
LOG_MAX_SIZE_MB="50"
LOG_BACKUP_COUNT="5"

# -------------------- Calibre Integration --------------------
CALIBRE_ENABLED="false"
CALIBRE_LIBRARY_PATH="/path/to/calibre/library"

# -------------------- Book Organization --------------------
ENRICH_BOOK_METADATA="true"
ENRICH_BOOK_METADATA_ONLINE="false"
CONVERT_PDF_TO_EPUB="false"

# Book Format Priority (highest to lowest priority)
# Default: EPUB > MOBI > AZW3 > AZW > PDF
# The system will skip organizing a book if a better format is already organized
BOOK_FORMAT_PRIORITY="epub,mobi,azw3,azw,pdf"

# -------------------- Music Organization --------------------
ENRICH_MUSIC_METADATA_ONLINE="false"

# -------------------- Last.fm API (for music genres) --------------------
LASTFM_API_KEY=""

# -------------------- OpenSubtitles API (for subtitle downloads) --------------------
# Get API key at: https://www.opensubtitles.com/en/consumers
# Free account: 20 downloads per day limit
OPENSUBTITLES_API_KEY="your_api_key_here"
OPENSUBTITLES_USERNAME="your_username_here"
OPENSUBTITLES_PASSWORD="your_password_here"

# Subtitle Downloader Settings
# Preferred subtitle languages in priority order (comma-separated)
SUBTITLE_LANGUAGES="pt,en,es"

# Skip download if subtitle already exists for language
SUBTITLE_SKIP_IF_EXISTS="true"

# Only download foreign language subtitles (for non-native content)
SUBTITLE_FOREIGN_ONLY="false"

# Daemon check interval in seconds (default: 24 hours = 86400)
SUBTITLE_DOWNLOAD_INTERVAL="86400"

# Enable/disable subtitle daemon
SUBTITLE_DAEMON_ENABLED="true"

# Log file for subtitle downloader (default: same as main system)
# Leave as default to use centralized logging in logs/organizer.log
SUBTITLE_LOG_FILE="./logs/organizer.log"

# Log level (DEBUG, INFO, WARNING, ERROR)
SUBTITLE_LOG_LEVEL="INFO"

# API rate limiting
OPENSUBTITLES_API_DELAY="1.0"
OPENSUBTITLES_MAX_RETRIES="3"
OPENSUBTITLES_RETRY_BACKOFF="5.0"
