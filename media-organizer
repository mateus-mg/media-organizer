#!/bin/bash
# Media Organizer CLI Wrapper

# ============================================
# DIRETÓRIO DO PROJETO
# ============================================
PROJECT_DIR="/media/mateus/Servidor/projetos/pessoal/media-organizer"

# ============================================
# IR PARA O DIRETÓRIO DO PROJETO
# ============================================
cd "$PROJECT_DIR" || {
    echo "❌ Erro: Não consigo acessar o diretório do projeto: $PROJECT_DIR"
    exit 1
}

# ============================================
# ATIVAR VIRTUAL ENV
# ============================================
if [ -d "venv" ] && [ -f "venv/bin/activate" ]; then
    source venv/bin/activate
fi

# ============================================
# EXECUTAR O SISTEMA
# ============================================
# Se sem argumentos, usa modo interativo
if [ $# -eq 0 ]; then
    exec python3 -m app.main interactive
else
    exec python3 -m app.main "$@"
fi
